<Window
    x:Class="AYVUNoLag.LicenseWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AYVU NoLag"
    Icon="pack://application:,,,/Assets/icon.ico"
    Width="420" Height="520"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Topmost="False">

    <Window.Resources>
        <!-- Input field style -->
        <Style x:Key="LicenseInput" TargetType="TextBox">
            <Setter Property="Background" Value="#0A0A0A" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="CaretBrush" Value="#FF4400" />
            <Setter Property="BorderBrush" Value="#242424" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Consolas, Courier New, monospace" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="CharacterCasing" Value="Upper" />
            <Setter Property="MaxLength" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Padding="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FF4400" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button -->
        <Style x:Key="LicenseBtn" TargetType="Button">
            <Setter Property="Background" Value="#FF4400" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5A1F" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D93A00" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Outline button (retry) -->
        <Style x:Key="LicenseBtnOutline" TargetType="Button" BasedOn="{StaticResource LicenseBtn}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#FF4400"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A0802" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2A0C02" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Outer border: rounded card with drop shadow -->
    <Border CornerRadius="16"
            Background="#020202"
            BorderBrush="#1F1F1F"
            BorderThickness="1"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.65" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Drag bar / close button ─────────────────────────────────── -->
            <Grid Grid.Row="0" Height="40" Margin="14,0">
                <Button x:Name="CloseBtn"
                        Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#505050"
                        FontSize="13"
                        Cursor="Hand"
                        Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1C1C1C" />
                                    <Setter Property="Foreground" Value="#A3A3A3" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ── Main content ────────────────────────────────────────────── -->
            <StackPanel Grid.Row="1" Margin="36,0,36,36">

                <!-- Logo + marca -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Border Width="52" Height="52" CornerRadius="14"
                            Background="#FF4400"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,14">
                        <TextBlock Text="N" Foreground="White" FontSize="26" FontWeight="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="AYVU NoLag"
                               Foreground="#F5F5F5"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Versão licenciada"
                               Foreground="#505050"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0" />
                </StackPanel>

                <!-- Subtítulo -->
                <TextBlock x:Name="SubtitleText"
                           Text="Digite seu ID de acesso para continuar"
                           Foreground="#A3A3A3"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16" />

                <!-- Campo de ID -->
                <TextBox x:Name="IdInput"
                         Style="{StaticResource LicenseInput}"
                         KeyDown="IdInput_KeyDown"
                         TextChanged="IdInput_TextChanged"
                         Margin="0,0,0,10" />

                <!-- Mensagem de feedback -->
                <TextBlock x:Name="FeedbackText"
                           Text=""
                           Foreground="#FF4400"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,0,0,12" />

                <!-- Spinner de loading -->
                <Border x:Name="SpinnerPanel"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,12"
                        Visibility="Collapsed">
                    <TextBlock Text="Verificando..."
                               Foreground="#A3A3A3"
                               FontSize="12" />
                </Border>

                <!-- Botão principal -->
                <Button x:Name="ValidateBtn"
                        Content="Acessar"
                        Style="{StaticResource LicenseBtn}"
                        Click="ValidateBtn_Click"
                        Margin="0,0,0,10" />

                <!-- Botão de retry (sem internet) -->
                <Button x:Name="RetryBtn"
                        Content="Tentar novamente"
                        Style="{StaticResource LicenseBtnOutline}"
                        Visibility="Collapsed"
                        Click="RetryBtn_Click"
                        Margin="0,0,0,0" />

            </StackPanel>
        </Grid>
    </Border>
</Window>
