<Window x:Class="AYVUNoLag.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AYVU NoLag"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="1200" Height="820"
        MinWidth="960" MinHeight="580"
        Background="{StaticResource AyvuBg}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="60" ResizeBorderThickness="7"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource AyvuBg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════════
                 BARRA DE TÍTULO
            ══════════════════════════════════════════════════════════ -->
            <Grid x:Name="TitleBar" Grid.Row="0" Margin="24,0,24,0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" Background="{StaticResource AyvuGreen}"
                            CornerRadius="6" Margin="0,0,10,0">
                        <TextBlock Text="N" Foreground="White" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </Border>
                    <TextBlock Text="AYVU NoLag"
                               Foreground="{StaticResource AyvuText}"
                               FontSize="18" FontWeight="SemiBold" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Border Style="{StaticResource VersionBadge}">
                        <TextBlock Text="v1.7.3" Foreground="{StaticResource AyvuText}"
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <Border x:Name="LicenseBadge"
                            Background="#0A0A0A" BorderBrush="#242424" BorderThickness="1"
                            CornerRadius="5" Padding="10,4" Margin="6,2,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="LicenseBadgeText"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource AyvuMuted}"/>
                    </Border>
                    <!-- Input Lag badge -->
                    <Border x:Name="InputLagBadge"
                            Background="#0A0A0A" BorderBrush="#242424" BorderThickness="1"
                            CornerRadius="5" Padding="10,4" Margin="6,2,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="InputLagBadgeText"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#EF4444"/>
                    </Border>

                    <!-- WARP status badge -->
                    <Border x:Name="WarpBadge"
                            Background="#0A0A0A" BorderBrush="#242424" BorderThickness="1"
                            CornerRadius="5" Padding="10,4" Margin="6,2,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="WarpBadgeText"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#F5A623"/>
                    </Border>

                    <Border x:Name="StatusBadge"
                            Background="#0A0A0A" BorderBrush="#242424" BorderThickness="1"
                            CornerRadius="5" Padding="10,4" Margin="12,2,0,0">
                        <TextBlock x:Name="StatusPillText" Text="● Pronto"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AyvuMuted}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="-" Style="{StaticResource WindowChromeButton}"
                            ToolTip="Minimizar" Click="MinimizeWindow_Click"/>
                    <Button Content="□" Style="{StaticResource WindowChromeButton}"
                            ToolTip="Maximizar" Click="MaximizeWindow_Click"/>
                    <Button Content="×" Style="{StaticResource WindowChromeButton}"
                            ToolTip="Fechar"    Click="CloseWindow_Click"/>
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 BARRA DE FERRAMENTAS
            ══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="24,10,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status text -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="StatusBarText"
                               Text="Pronto. Clique em Analisar para medir sua conexão."
                               Foreground="{StaticResource AyvuMuted}"
                               FontSize="12" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="LastScanLabel" Text=""
                               Foreground="{StaticResource AyvuMuted}"
                               FontSize="10" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Botões de ação -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ScanButton" Content="Analisar"
                            Style="{StaticResource OutlineAyvuNativeButton}"
                            Height="44" Padding="24,0" Margin="0,0,8,0"
                            ToolTip="Executa ping, jitter, packet loss e DNS"
                            Click="ScanButton_Click"/>
                    <!-- Seletor de jogo -->
                    <ComboBox x:Name="GameComboBox"
                              Width="180" Height="44" Margin="8,0,0,0"
                              MaxDropDownHeight="260"
                              DisplayMemberPath="Name"
                              ToolTip="Selecione o jogo para priorizar o processo (opcional)"/>

                    <!-- Botão único: Otimizar -->
                    <Button x:Name="OtimizarButton"
                            Content="▶  Otimizar"
                            Style="{StaticResource PrimaryAyvuNativeButton}"
                            Height="44" Padding="24,0" Margin="8,0,0,0"
                            ToolTip="Aplica Boost + Input Lag de uma vez"
                            Click="OtimizarButton_Click"/>

                    <Button x:Name="PararOtimizacaoButton"
                            Content="⏹  Parar"
                            Style="{StaticResource OutlineAyvuNativeButton}"
                            Height="44" Padding="24,0" Margin="8,0,0,0"
                            Visibility="Collapsed"
                            ToolTip="Reverte todas as otimizações"
                            Click="PararOtimizacaoButton_Click"/>

                    <!-- WARP toggle (oculto até estar pronto) -->
                    <Button x:Name="WarpButton"
                            Content="◎  WARP"
                            Style="{StaticResource OutlineAyvuNativeButton}"
                            Height="44" Padding="24,0" Margin="8,0,0,0"
                            Visibility="Collapsed"
                            Click="WarpButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- ProgressBar durante análise -->
            <ProgressBar x:Name="ExecutionProgress"
                         Grid.Row="1" Height="3"
                         VerticalAlignment="Bottom"
                         Margin="24,0,24,0"
                         Visibility="Collapsed"
                         IsIndeterminate="True"
                         Foreground="{StaticResource AyvuGreen}"
                         Background="Transparent" BorderThickness="0"/>

            <!-- ══════════════════════════════════════════════════════════
                 CONTEÚDO PRINCIPAL — ÚNICA PÁGINA, BLOCOS RESPONSIVOS
            ══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="24,0,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- System metrics -->
                    <RowDefinition Height="Auto"/>   <!-- Network metric cards -->
                    <RowDefinition Height="1.8*"/>   <!-- Ping + (Veredicto | Jogos) -->
                    <RowDefinition Height="1*"/>     <!-- DNS + Boost + Log -->
                </Grid.RowDefinitions>

                <!-- ── ROW 0: Monitor em tempo real (estilo Windows Boost) ── -->
                <Border Grid.Row="0" Style="{StaticResource LargePanel}" Padding="16" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                    CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Monitor em tempo real"
                                       Foreground="{StaticResource AyvuText}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="#030303" CornerRadius="7"
                                Padding="10" Margin="0,10,0,0">
                            <UniformGrid Columns="4">
                                <Border Background="#080808" BorderBrush="#1C1C1C" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="0,0,6,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="36"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="8" Height="8" Background="{StaticResource AyvuGreen}" CornerRadius="2" Margin="0,1,6,0"/>
                                                <TextBlock Text="CPU" Foreground="{StaticResource AyvuText}" FontSize="10" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock x:Name="CardCpuValue" Text="--%" Foreground="{StaticResource AyvuText}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                <TextBlock x:Name="CardCpuLabel" Text="de uso" Foreground="{StaticResource AyvuMuted}" FontSize="8" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                        <Canvas x:Name="CpuSparkline" Grid.Row="1" Height="36" ClipToBounds="True" Margin="0,6,0,0"/>
                                    </Grid>
                                </Border>

                                <Border Background="#080808" BorderBrush="#1C1C1C" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="2,0,6,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="36"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="8" Height="8" Background="{StaticResource AyvuGreen}" CornerRadius="2" Margin="0,1,6,0"/>
                                                <TextBlock Text="RAM" Foreground="{StaticResource AyvuText}" FontSize="10" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock x:Name="CardRamValue" Text="-- GB" Foreground="{StaticResource AyvuText}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                <TextBlock x:Name="CardRamLabel" Text="de uso" Foreground="{StaticResource AyvuMuted}" FontSize="8" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                        <Canvas x:Name="RamSparkline" Grid.Row="1" Height="36" ClipToBounds="True" Margin="0,6,0,0"/>
                                    </Grid>
                                </Border>

                                <Border Background="#080808" BorderBrush="#1C1C1C" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="2,0,6,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="36"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="8" Height="8" Background="{StaticResource AyvuGreen}" CornerRadius="2" Margin="0,1,6,0"/>
                                                <TextBlock Text="GPU" Foreground="{StaticResource AyvuText}" FontSize="10" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock x:Name="CardGpuValue" Text="--%" Foreground="{StaticResource AyvuText}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                <TextBlock x:Name="CardGpuLabel" Text="de uso" Foreground="{StaticResource AyvuMuted}" FontSize="8" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                        <Canvas x:Name="GpuSparkline" Grid.Row="1" Height="36" ClipToBounds="True" Margin="0,6,0,0"/>
                                    </Grid>
                                </Border>

                                <Border Background="#080808" BorderBrush="#1C1C1C" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="2,0,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="36"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="8" Height="8" Background="{StaticResource AyvuGreen}" CornerRadius="2" Margin="0,1,6,0"/>
                                                <TextBlock Text="Disco" Foreground="{StaticResource AyvuText}" FontSize="10" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock x:Name="CardDiskValue" Text="--%" Foreground="{StaticResource AyvuText}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                <TextBlock x:Name="CardDiskLabel" Text="de uso" Foreground="{StaticResource AyvuMuted}" FontSize="8" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                        <Canvas x:Name="DiskSparkline" Grid.Row="1" Height="36" ClipToBounds="True" Margin="0,6,0,0"/>
                                    </Grid>
                                </Border>
                            </UniformGrid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── ROW 1: Network metric cards ──────────────────── -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,10">
                    <Border Style="{StaticResource MetricBox}" Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock Text="PING MÉDIO" Foreground="{StaticResource AyvuMuted}"
                                       FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock x:Name="CardPingValue" Text="-- ms"
                                       Foreground="{StaticResource AyvuText}"
                                       FontSize="22" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="CardPingLabel" Text="Aguardando"
                                       Foreground="{StaticResource AyvuMuted}"
                                       FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}" Margin="5,0,5,0">
                        <StackPanel>
                            <TextBlock Text="JITTER" Foreground="{StaticResource AyvuMuted}"
                                       FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock x:Name="CardJitterValue" Text="-- ms"
                                       Foreground="{StaticResource AyvuText}"
                                       FontSize="22" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="CardJitterLabel" Text="Aguardando"
                                       Foreground="{StaticResource AyvuMuted}"
                                       FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}" Margin="5,0,5,0">
                        <StackPanel>
                            <TextBlock Text="PACKET LOSS" Foreground="{StaticResource AyvuMuted}"
                                       FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock x:Name="CardLossValue" Text="--%"
                                       Foreground="{StaticResource AyvuText}"
                                       FontSize="22" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="CardLossLabel" Text="Aguardando"
                                       Foreground="{StaticResource AyvuMuted}"
                                       FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}" Margin="5,0,0,0">
                        <StackPanel>
                            <TextBlock Text="MELHOR PING" Foreground="{StaticResource AyvuMuted}"
                                       FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock x:Name="CardBestValue" Text="-- ms"
                                       Foreground="{StaticResource AyvuText}"
                                       FontSize="22" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="CardBestLabel" Text="Aguardando"
                                       Foreground="{StaticResource AyvuMuted}"
                                       FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ── ROW 2: Amostras de Ping | Veredicto + Jogos ──── -->
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="0.95*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Amostras de Ping -->
                    <Border Grid.Column="0" Style="{StaticResource LargePanel}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                        CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Amostras de Ping"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" Margin="0,14,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,6,0">
                                <ListView x:Name="PingList" BorderThickness="0" Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Alvo"    DisplayMemberBinding="{Binding Target}"    Width="130"/>
                                            <GridViewColumn Header="Ping ms" DisplayMemberBinding="{Binding LatencyMs}" Width="80"/>
                                            <GridViewColumn Header="Status"  DisplayMemberBinding="{Binding Status}"   Width="180"/>
                                            <GridViewColumn Header="OK"      DisplayMemberBinding="{Binding Success}"  Width="50"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- MSI Mode (ao lado de Amostras de Ping) -->
                    <Border Grid.Column="2" Style="{StaticResource LargePanel}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                        CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="MSI Mode"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,6,0">
                                <ItemsControl x:Name="MsiDeviceList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A0A0A" BorderBrush="#1C1C1C"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="10,8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="#1A0802" BorderBrush="#FF4400"
                                                                    BorderThickness="1" CornerRadius="3"
                                                                    Padding="5,1" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding Category}"
                                                                           Foreground="#FF4400" FontSize="9"
                                                                           FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                       Foreground="{Binding StatusBrush}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource AyvuText}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="1"
                                                              IsChecked="{Binding MsiEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center" Margin="8,0,0,0"
                                                              Tag="{Binding PnpId}"
                                                              Click="MsiDeviceToggle_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="MsiEnableAllBtn"
                                        Content="Ativar todos"
                                        Style="{StaticResource PrimaryAyvuNativeButton}"
                                        Height="32" Padding="12,0" FontSize="11"
                                        Click="MsiEnableAll_Click"/>
                                <Button x:Name="MsiDisableAllBtn"
                                        Content="Desativar"
                                        Style="{StaticResource OutlineAyvuNativeButton}"
                                        Height="32" Padding="12,0" FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="MsiDisableAll_Click"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" x:Name="MsiApplyStatus" Text=""
                                       Foreground="{StaticResource AyvuMuted}"
                                       FontSize="10" Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Veredicto + Jogos (stacked) -->
                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Veredicto -->
                        <Border Grid.Row="0" Style="{StaticResource LargePanel}" Padding="14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                            CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Diagnóstico"
                                               Foreground="{StaticResource AyvuText}"
                                               FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock x:Name="VerdictText"
                                           Text="Execute uma análise para ver o diagnóstico."
                                           Foreground="{StaticResource AyvuMuted}"
                                           FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                <TextBlock x:Name="VerdictTimestamp" Text=""
                                           Foreground="{StaticResource AyvuMuted}"
                                           FontSize="10" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Jogos Detectados -->
                        <Border Grid.Row="1" Style="{StaticResource LargePanel}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                                CornerRadius="2" Margin="0,0,10,0"/>
                                        <TextBlock Text="Jogos Detectados"
                                                   Foreground="{StaticResource AyvuText}"
                                                   FontSize="15" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <Button x:Name="PrioritizeButton" Grid.Column="1"
                                            Content="↑ Priorizar"
                                            Style="{StaticResource OutlineAyvuNativeButton}"
                                            Height="32" Padding="14,0" FontSize="11"
                                            VerticalAlignment="Center"
                                            Click="PrioritizeButton_Click"/>
                                </Grid>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0,0,6,0">
                                    <ListView x:Name="JogosList" BorderThickness="0"
                                              Background="Transparent" SelectionMode="Single">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Processo" DisplayMemberBinding="{Binding Name}"     Width="130"/>
                                                <GridViewColumn Header="RAM MB"   DisplayMemberBinding="{Binding MemoryMb}" Width="70"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </ScrollViewer>
                                <Border Grid.Row="2" Background="#0A0A0A"
                                        BorderBrush="{StaticResource AyvuBorder}"
                                        BorderThickness="1" CornerRadius="5"
                                        Margin="0,8,0,0" Padding="10,6">
                                    <TextBlock x:Name="JogosStatusText"
                                               Text="Selecione um processo e clique em Priorizar."
                                               Foreground="{StaticResource AyvuMuted}" FontSize="11"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ── ROW 3: DNS | GPU Mode | Otimizações | Log ─── -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Resolução DNS -->
                    <Border Grid.Column="0" Style="{StaticResource LargePanel}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                        CornerRadius="2" Margin="0,0,10,0"/>
                                <TextBlock Text="Resolução DNS"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" Margin="0,14,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,6,0">
                                <ListView x:Name="DnsList" BorderThickness="0" Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Host"    DisplayMemberBinding="{Binding Host}"      Width="130"/>
                                            <GridViewColumn Header="ms"      DisplayMemberBinding="{Binding ElapsedMs}" Width="55"/>
                                            <GridViewColumn Header="Status"  DisplayMemberBinding="{Binding Status}"   Width="90"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- MSI Mode legado (mantido oculto; painel ativo fica ao lado de Amostras de Ping) -->
                    <Border Grid.Column="2" Style="{StaticResource LargePanel}" Margin="0" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                        CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="MSI Mode"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Lista de dispositivos com toggle -->
                            <ScrollViewer Grid.Row="1" Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,6,0">
                                <ItemsControl x:Name="MsiDeviceListLegacy">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A0A0A" BorderBrush="#1C1C1C"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="10,8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="#1A0802" BorderBrush="#FF4400"
                                                                    BorderThickness="1" CornerRadius="3"
                                                                    Padding="5,1" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding Category}"
                                                                           Foreground="#FF4400" FontSize="9"
                                                                           FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                       Foreground="{Binding StatusBrush}"
                                                                       FontSize="9" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource AyvuText}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="1"
                                                              IsChecked="{Binding MsiEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center" Margin="8,0,0,0"
                                                              Tag="{Binding PnpId}"
                                                              Click="MsiDeviceToggle_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Botões de ação rápida -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="MsiEnableAllBtnLegacy"
                                        Content="Ativar todos"
                                        Style="{StaticResource PrimaryAyvuNativeButton}"
                                        Height="32" Padding="12,0" FontSize="11"
                                        Click="MsiEnableAll_Click"/>
                                <Button x:Name="MsiDisableAllBtnLegacy"
                                        Content="Desativar"
                                        Style="{StaticResource OutlineAyvuNativeButton}"
                                        Height="32" Padding="12,0" FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="MsiDisableAll_Click"/>
                            </StackPanel>

                            <!-- Status resultado -->
                            <TextBlock Grid.Row="3" x:Name="MsiApplyStatusLegacy" Text=""
                                       Foreground="{StaticResource AyvuMuted}"
                                       FontSize="10" Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Otimizações (Boost + Input Lag unificados) -->
                    <Border Grid.Column="2" Style="{StaticResource LargePanel}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                        CornerRadius="2" Margin="0,0,10,0"/>
                                <TextBlock Text="Otimizações"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock x:Name="OtimizacoesSubtitle"
                                           Text="  —  clique em Otimizar para ativar"
                                           Foreground="{StaticResource AyvuMuted}"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" Margin="0,14,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,6,0">
                                <ListView x:Name="OtimizacoesList" BorderThickness="0" Background="Transparent">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Otimização" DisplayMemberBinding="{Binding Name}"    Width="140"/>
                                            <GridViewColumn Header="OK"         DisplayMemberBinding="{Binding Success}" Width="40"/>
                                            <GridViewColumn Header="Detalhe"    DisplayMemberBinding="{Binding Detail}"  Width="200"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Log de Atividade -->
                    <Border Grid.Column="4" Style="{StaticResource LargePanel}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="3" Height="16" Background="{StaticResource AyvuGreen}"
                                        CornerRadius="2" Margin="0,0,10,0"/>
                                <TextBlock Text="Log de Atividade"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <ScrollViewer x:Name="LogScroll" Grid.Row="1" Margin="0,14,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="0,0,6,0">
                                <ItemsControl x:Name="LogList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource LogEntryBox}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Message}"
                                                                   Foreground="{StaticResource AyvuText}"
                                                                   FontSize="11" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Time}"
                                                                   Foreground="{StaticResource AyvuMuted}"
                                                                   FontSize="9" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Status}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Margin="8,0,0,0" VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── Banner de atualização ────────────────────────────────────── -->
            <Grid x:Name="UpdateBanner"
                  Grid.RowSpan="3"
                  Visibility="Collapsed"
                  Background="#88000000"
                  Panel.ZIndex="200">
                <Border MaxWidth="460"
                        Background="#111111"
                        BorderBrush="{StaticResource AyvuGreen}"
                        BorderThickness="1"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="36,28">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" Background="{StaticResource AyvuGreen}"
                                        CornerRadius="4" Margin="0,0,10,0" VerticalAlignment="Center" />
                                <TextBlock Text="Atualização disponível"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕"
                                    Style="{StaticResource WindowChromeButton}"
                                    Width="32" Height="32"
                                    VerticalAlignment="Center"
                                    ToolTip="Dispensar"
                                    Click="UpdateDismiss_Click" />
                        </Grid>
                        <TextBlock x:Name="UpdateBannerText"
                                   Text="Nova versão disponível"
                                   Foreground="{StaticResource AyvuMuted}"
                                   FontSize="13" Margin="0,0,0,24"
                                   TextWrapping="Wrap" />
                        <StackPanel x:Name="UpdateProgressPanel" Visibility="Collapsed" Margin="0,0,0,20">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Baixando..."
                                           Foreground="{StaticResource AyvuMuted}"
                                           FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="UpdateProgressText" Text="0%"
                                           Foreground="{StaticResource AyvuGreen}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </Grid>
                            <ProgressBar x:Name="UpdateProgressBar"
                                         Height="4" Minimum="0" Maximum="100"
                                         Foreground="{StaticResource AyvuGreen}"
                                         Background="#2A2A2A" BorderThickness="0" />
                        </StackPanel>
                        <StackPanel x:Name="UpdateTextPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Agora não"
                                    Style="{StaticResource OutlineAyvuNativeButton}"
                                    Height="40" Padding="20,0"
                                    Click="UpdateDismiss_Click" />
                            <Button x:Name="UpdateInstallButton"
                                    Content="Atualizar agora"
                                    Style="{StaticResource PrimaryAyvuNativeButton}"
                                    Height="40" Padding="20,0" Margin="10,0,0,0"
                                    Click="UpdateInstall_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Modal: reinicialização MSI Mode ──────────────────────────── -->
            <Grid x:Name="RestartBanner"
                  Grid.RowSpan="3"
                  Visibility="Collapsed"
                  Background="#88000000"
                  Panel.ZIndex="201">
                <Border MaxWidth="460"
                        Background="#111111"
                        BorderBrush="#F5A623"
                        BorderThickness="1"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="36,28">
                    <StackPanel>
                        <!-- Cabeçalho -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8" Background="#F5A623"
                                        CornerRadius="4" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Reinicialização necessária"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕"
                                    Style="{StaticResource WindowChromeButton}"
                                    Width="32" Height="32" VerticalAlignment="Center"
                                    Click="RestartDismiss_Click"/>
                        </Grid>

                        <!-- Ícone + mensagem -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" Background="#1A0F00"
                                    BorderBrush="#F5A623" BorderThickness="1"
                                    CornerRadius="8" Margin="0,0,14,0">
                                <TextBlock Text="⚡" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MSI Mode alterado com sucesso"
                                           Foreground="{StaticResource AyvuText}"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Configuração de hardware aplicada"
                                           Foreground="#F5A623" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                   Foreground="{StaticResource AyvuMuted}" Margin="0,0,0,24">
                            <Run Text="O MSI Mode (Message Signaled Interrupts) foi alterado em um ou mais dispositivos. Esta mudança reduz a latência de interrupções — estabilizando o frametime (GPU) e o jitter de pacotes (rede)."/>
                            <LineBreak/>
                            <LineBreak/>
                            <Run Text="Esta é uma configuração única e permanente. Reinicie o computador para que o driver carregue a nova configuração — você não precisará repetir." FontWeight="SemiBold" Foreground="{StaticResource AyvuText}"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Reiniciar depois"
                                    Style="{StaticResource OutlineAyvuNativeButton}"
                                    Height="40" Padding="20,0"
                                    Click="RestartDismiss_Click"/>
                            <Button Content="⟳  Reiniciar agora"
                                    Style="{StaticResource PrimaryAyvuNativeButton}"
                                    Height="40" Padding="20,0" Margin="10,0,0,0"
                                    Click="RestartNow_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Modal: instalar WARP ──────────────────────────────────────── -->
            <Grid x:Name="WarpInstallBanner"
                  Grid.RowSpan="3"
                  Visibility="Collapsed"
                  Background="#88000000"
                  Panel.ZIndex="199">
                <Border MaxWidth="460"
                        Background="#111111"
                        BorderBrush="#F5A623"
                        BorderThickness="1"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="36,28">
                    <StackPanel>
                        <!-- Cabeçalho -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="8" Height="8" Background="#F5A623"
                                    CornerRadius="4" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="WarpInstallTitle"
                                       Text="Configurar WireGuard Tunnel"
                                       Foreground="{StaticResource AyvuText}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Descrição (visível antes de instalar) -->
                        <TextBlock x:Name="WarpInstallDesc"
                                   Text="O AYVU NoLag irá baixar o WireGuard Engine (~10 MB) e conectar diretamente à rede Cloudflare. Nenhum app adicional será instalado."
                                   Foreground="{StaticResource AyvuMuted}"
                                   FontSize="13" TextWrapping="Wrap" Margin="0,0,0,24"/>

                        <!-- Progresso (visível durante download/instalação) -->
                        <StackPanel x:Name="WarpInstallProgress" Visibility="Collapsed" Margin="0,0,0,20">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="WarpInstallStatus"
                                           Text="Baixando..."
                                           Foreground="{StaticResource AyvuMuted}"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="WarpInstallPct"
                                           Text="0%"
                                           Foreground="#F5A623"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar x:Name="WarpInstallBar"
                                         Height="4" Minimum="0" Maximum="100"
                                         Foreground="#F5A623"
                                         Background="#2A2A2A" BorderThickness="0"/>
                        </StackPanel>

                        <!-- Botões -->
                        <StackPanel x:Name="WarpInstallButtons" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Agora não"
                                    Style="{StaticResource OutlineAyvuNativeButton}"
                                    Height="40" Padding="20,0"
                                    Click="WarpInstallDismiss_Click"/>
                            <Button x:Name="WarpInstallConfirmBtn"
                                    Content="Configurar agora"
                                    Style="{StaticResource PrimaryAyvuNativeButton}"
                                    Height="40" Padding="20,0" Margin="10,0,0,0"
                                    Click="WarpInstallConfirm_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
