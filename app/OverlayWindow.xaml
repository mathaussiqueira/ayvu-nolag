<Window x:Class="AYVUNoLag.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AYVU NoLag Overlay"
        Width="260" Height="108"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Border x:Name="RootBorder"
            Background="#DD111111"
            BorderBrush="#FF4400"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">

        <Grid Margin="14,10,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logo N -->
                    <Border Width="16" Height="16" Background="#FF4400"
                            CornerRadius="3" Margin="0,0,7,0">
                        <TextBlock Text="N" Foreground="White" FontSize="9"
                                   FontWeight="Bold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="AYVU NoLag"
                               Foreground="#F5F5F5" FontSize="11"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>

                    <!-- Status pill -->
                    <Border x:Name="StatusPill"
                            Background="#1A1A1A" BorderBrush="#303030"
                            BorderThickness="1" CornerRadius="4"
                            Padding="6,2" Margin="8,0,0,0">
                        <TextBlock x:Name="StatusText"
                                   Text="● Normal"
                                   FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="#A3A3A3"/>
                    </Border>
                </StackPanel>

                <!-- Fechar -->
                <Button Grid.Column="1"
                        Content="×"
                        Click="CloseOverlay_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#555555"
                        FontSize="15"
                        FontFamily="Segoe UI"
                        Cursor="Hand"
                        Width="18" Height="18"
                        Padding="0" Margin="0,0,-2,0"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"/>
            </Grid>

            <!-- ── Métricas ────────────────────────────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ping -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="PingValue" Text="--"
                               Foreground="#F5F5F5" FontSize="20"
                               FontWeight="Bold" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="ms  ping"
                               Foreground="#555555" FontSize="9"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Column="1" Fill="#2A2A2A" VerticalAlignment="Stretch" Margin="0,2"/>

                <!-- Jitter -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="JitterValue" Text="--"
                               Foreground="#F5F5F5" FontSize="20"
                               FontWeight="Bold" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="ms  jitter"
                               Foreground="#555555" FontSize="9"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Column="3" Fill="#2A2A2A" VerticalAlignment="Stretch" Margin="0,2"/>

                <!-- Loss -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock x:Name="LossValue" Text="--"
                               Foreground="#F5F5F5" FontSize="20"
                               FontWeight="Bold" FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="%  loss"
                               Foreground="#555555" FontSize="9"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
