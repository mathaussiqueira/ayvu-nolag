<Application x:Class="AYVUNoLag.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="LicenseWindow.xaml">
    <Application.Resources>

        <!-- ── Cores ───────────────────────────────────────────────────────── -->
        <Color x:Key="AyvuBgColor">#020202</Color>
        <Color x:Key="AyvuPanelColor">#111111</Color>
        <Color x:Key="AyvuPanelAltColor">#050505</Color>
        <Color x:Key="AyvuGreenColor">#FF4400</Color>
        <Color x:Key="AyvuTextColor">#F5F5F5</Color>
        <Color x:Key="AyvuMutedColor">#A3A3A3</Color>
        <Color x:Key="AyvuBorderColor">#242424</Color>
        <Color x:Key="AyvuWarnColor">#F5A623</Color>
        <Color x:Key="AyvuSuccessColor">#22C55E</Color>
        <Color x:Key="AyvuDangerColor">#EF4444</Color>

        <SolidColorBrush x:Key="AyvuBg"       Color="{StaticResource AyvuBgColor}"/>
        <SolidColorBrush x:Key="AyvuPanel"    Color="{StaticResource AyvuPanelColor}"/>
        <SolidColorBrush x:Key="AyvuPanelAlt" Color="{StaticResource AyvuPanelAltColor}"/>
        <SolidColorBrush x:Key="AyvuGreen"    Color="{StaticResource AyvuGreenColor}"/>
        <SolidColorBrush x:Key="AyvuText"     Color="{StaticResource AyvuTextColor}"/>
        <SolidColorBrush x:Key="AyvuMuted"    Color="{StaticResource AyvuMutedColor}"/>
        <SolidColorBrush x:Key="AyvuBorder"   Color="{StaticResource AyvuBorderColor}"/>
        <SolidColorBrush x:Key="AyvuWarn"     Color="{StaticResource AyvuWarnColor}"/>
        <SolidColorBrush x:Key="AyvuSuccess"  Color="{StaticResource AyvuSuccessColor}"/>
        <SolidColorBrush x:Key="AyvuDanger"   Color="{StaticResource AyvuDangerColor}"/>

        <!-- ── Botões de chrome ─────────────────────────────────────────────── -->
        <Style x:Key="WindowChromeButton" TargetType="Button">
            <Setter Property="Width"           Value="34"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Margin"          Value="2,0,0,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource AyvuMuted}"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#171717"/>
                    <Setter Property="Foreground" Value="{StaticResource AyvuText}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Botão primário ───────────────────────────────────────────────── -->
        <Style x:Key="PrimaryAyvuNativeButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AyvuGreen}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AyvuGreen}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#FF5A1F"/>
                    <Setter Property="BorderBrush" Value="#FF5A1F"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background"  Value="#D93A00"/>
                    <Setter Property="BorderBrush" Value="#D93A00"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.42"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Botão outline ────────────────────────────────────────────────── -->
        <Style x:Key="OutlineAyvuNativeButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AyvuGreen}"/>
            <Setter Property="Foreground"      Value="{StaticResource AyvuText}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#1A0802"/>
                    <Setter Property="BorderBrush" Value="#FF6A33"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2A0C02"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.42"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── NavButton (inativo) ──────────────────────────────────────────── -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height"          Value="48"/>
            <Setter Property="MinWidth"        Value="96"/>
            <Setter Property="Padding"         Value="24,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="#121212"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AyvuBorder}"/>
            <Setter Property="Foreground"      Value="{StaticResource AyvuText}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AyvuGreen}"/>
                    <Setter Property="Background"  Value="#181818"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── NavButton (ativo/selecionado) ────────────────────────────────── -->
        <Style x:Key="NavButtonSelected" TargetType="Button">
            <Setter Property="Height"          Value="48"/>
            <Setter Property="MinWidth"        Value="96"/>
            <Setter Property="Padding"         Value="24,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="{StaticResource AyvuGreen}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AyvuGreen}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#FF5A1F"/>
                    <Setter Property="BorderBrush" Value="#FF5A1F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Panels e cards ───────────────────────────────────────────────── -->
        <Style x:Key="LargePanel" TargetType="Border">
            <Setter Property="Background"       Value="#111111"/>
            <Setter Property="BorderBrush"      Value="#1F1F1F"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="14"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>

        <Style x:Key="MetricBox" TargetType="Border">
            <Setter Property="Background"       Value="#050505"/>
            <Setter Property="BorderBrush"      Value="#161616"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="7"/>
            <Setter Property="Padding"          Value="14"/>
        </Style>

        <Style x:Key="LogEntryBox" TargetType="Border">
            <Setter Property="Background"       Value="#0A0A0A"/>
            <Setter Property="BorderBrush"      Value="#1C1C1C"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="9"/>
            <Setter Property="Padding"          Value="10"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>

        <Style x:Key="VersionBadge" TargetType="Border">
            <Setter Property="Background"       Value="#181818"/>
            <Setter Property="BorderBrush"      Value="#2A2A2A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="5"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="Margin"           Value="10,2,0,0"/>
        </Style>

        <!-- ── ListView escuro ──────────────────────────────────────────────── -->
        <Style TargetType="ListView">
            <Setter Property="Background"      Value="#050505"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AyvuBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="{StaticResource AyvuText}"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource AyvuText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="4,7"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111111"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A0600"/>
                    <Setter Property="Foreground"  Value="{StaticResource AyvuGreen}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="#0A0A0A"/>
            <Setter Property="Foreground"      Value="{StaticResource AyvuMuted}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="BorderBrush"     Value="{StaticResource AyvuBorder}"/>
        </Style>

        <!-- ── ComboBox escuro ──────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"            Value="#0F0F0F"/>
            <Setter Property="Foreground"            Value="#E5E5E5"/>
            <Setter Property="BorderBrush"           Value="#303030"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="FontFamily"            Value="Segoe UI"/>
            <Setter Property="Padding"               Value="10,0"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Caixa principal -->
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Texto selecionado -->
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"
                                                      TextBlock.Foreground="#E5E5E5"
                                                      TextBlock.FontSize="13"/>
                                    <!-- Placeholder quando vazio -->
                                    <TextBlock x:Name="Placeholder"
                                               Grid.Column="0"
                                               Text="Selecionar jogo..."
                                               Foreground="#666666"
                                               FontSize="13"
                                               Margin="{TemplateBinding Padding}"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Visibility="Collapsed"/>
                                    <!-- Seta -->
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 5 5 L 10 0"
                                          Stroke="#888888" StrokeThickness="1.5"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                    <!-- Toggle invisível (para capturar clique) -->
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Focusable="False" ClickMode="Press"/>
                                </Grid>
                            </Border>
                            <!-- Popup dropdown -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropBorder"
                                        Background="#111111"
                                        BorderBrush="#303030"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,4,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="4">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover na caixa principal -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#FF4400"/>
                            </Trigger>
                            <!-- Aberto -->
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#FF4400"/>
                            </Trigger>
                            <!-- Placeholder quando nada selecionado -->
                            <Trigger Property="SelectedIndex" Value="-1">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Item do ComboBox -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="#E5E5E5"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="Padding"     Value="10,7"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}"
                                Margin="0,1">
                            <ContentPresenter TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A0802"/>
                                <Setter Property="Foreground" Value="#FF4400"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A0802"/>
                                <Setter Property="Foreground" Value="#FF4400"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollBar fina (4px, cor do accent) ──────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"    Value="4"/>
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="MaxWidth" Value="4"/>
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="4" MinWidth="4" MaxWidth="4" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" Width="4" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource AyvuGreen}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
